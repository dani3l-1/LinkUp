GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
NODE_ENV=development
SESSION_SECRET=your_session_secret_key_here
# Required in production; use an independent random value of at least 32 characters.
DATA_ENCRYPTION_KEY=your_64_byte_random_hex_key_here
# Admin emails can be non-.edu; they are allowed through signup and get admin access.
ADMIN_EMAILS=founder@university.edu,ops@gmail.com
# Pre-launch switch: true keeps every non-admin student on the waitlist.
# Set to false when LinkUp is ready to approve supported schools.
WAITLIST_MODE=true
DATA_DIR=./data
DATABASE_URL=
DATABASE_SSL=
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Optional PEM CA certificate when the database uses a private certificate authority.
DATABASE_SSL_CA=
PAYMENT_PROVIDER=stripe
PAYOUT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
APP_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:4000
VAPID_PUBLIC_KEY=your_web_push_vapid_public_key_here
VAPID_PRIVATE_KEY=your_web_push_vapid_private_key_here
VAPID_SUBJECT=mailto:your-linkup-email@gmail.com

# Increase either version when users must re-agree before using LinkUp services.
REQUIRED_TERMS_VERSION=v2026.05.1
REQUIRED_PRIVACY_VERSION=v2026.05.1

# Real email sending through SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-linkup-email@gmail.com
SMTP_PASS=your_email_app_password_here
EMAIL_FROM="LinkUp <your-linkup-email@gmail.com>"
